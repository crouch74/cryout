{
  "name": "the-stones-are-crying-outt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ui": "vite",
    "dev:rooms": "node room-service/server.ts",
    "generate:scenario-maps": "node scripts/generate-scenario-maps.mjs",
    "simulate": "node src/simulation/runSimulation.ts",
    "experiment": "node src/simulation/experiments/cli.ts",
    "experiment:all": "node src/simulation/experiments/cli.ts --all",
    "balance-search": "node src/simulation/balance/cli.ts",
    "optimize": "node --no-warnings src/simulation/optimizer/cli.ts",
    "optimize-scenario": "node --no-warnings src/simulation/optimizer/cli.ts",
    "simulator": "node src/simulation/cli/interactive.ts",
    "trajectories": "node src/simulation/trajectory/analyzeTrajectories.ts",
    "build": "tsc -p tsconfig.app.json && tsc -p tsconfig.room-service.json && vite build",
    "build:pages": "tsc -p tsconfig.app.json && tsc -p tsconfig.room-service.json && vite build --mode pages",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:engine": "node --test tests/unit/engine.test.ts tests/unit/replay.test.ts tests/integration/scenario-framework.test.ts",
    "test:ui": "node --test tests/unit/ui.test.ts tests/unit/ui-token-guards.test.ts tests/unit/world-map-anchor.test.ts tests/unit/world-map-token-layout.test.ts tests/unit/world-map-viewport.test.ts tests/unit/scenario-map-assets.test.ts tests/integration/permalinks.test.ts tests/unit/runtime.test.ts",
    "test:e2e": "node --test tests/integration/e2e.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "framer-motion": "^12.35.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "inquirer": "^12.11.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@esbuild/darwin-x64": "^0.27.3",
    "@eslint/js": "^9.39.1",
    "@rollup/rollup-darwin-x64": "^4.59.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
