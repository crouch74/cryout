{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@scenarios/*": ["scenarios/*"],
      "@engine-legacy/*": ["engine/legacy/*"]
    }
  },
  "include": [
    "core/**/*.ts",
    "scenarios/**/*.ts",
    "engine/**/*.ts",
    "content/index.ts",
    "content/base_design/**/*.ts",
    "content/scenarios/**/*.ts",
    "room-service/**/*.ts",
    "tests/**/*.ts",
    "src/mvp/runtime.ts",
    "src/mvp/urlState.ts",
    "src/mvp/gameUiHelpers.ts"
  ],
  "exclude": [
    "src/**/*"
  ]
}
