{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@features/*": ["src/features/*"],
      "@game/*": ["src/game/*"],
      "@engine/*": ["src/engine/*"],
      "@scenarios/*": ["src/scenarios/*"],
      "@ui/*": ["src/ui/*"],
      "@devtools/*": ["src/devtools/*"],
      "@i18n/*": ["src/i18n/*"],
      "@styles/*": ["src/styles/*"],
      "@assets/*": ["src/assets/*"]
    }
  },
  "include": [
    "src/engine/**/*.ts",
    "src/scenarios/**/*.ts",
    "src/i18n/**/*.ts",
    "src/features/room-session/**/*.ts",
    "room-service/**/*.ts"
  ],
  "exclude": [
    "src/app/**/*",
    "src/game/**/*",
    "src/ui/**/*",
    "src/devtools/**/*",
    "tests/**/*"
  ]
}
